DEBUG=False
DATABASE_URL=sqlite:///./carroo.db
SECRET_KEY=your-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ========== トラボックス設定 ==========
# ブラウザ自動化設定
TRABOX_HEADLESS=True

# トラボックスのテストアカウント情報
# ⚠️ 注意: 本番環境では絶対に公開リポジトリにコミットしないこと！
# テスト用のセパレートアカウントを使用することを推奨します
TRABOX_TEST_USERNAME=your_test_username
TRABOX_TEST_PASSWORD=your_test_password

# ========== WebKIT API設定 ==========
# XML-based API による自動投稿
# WEBKIT_API_KEY: 20桁のAPIキー（公式仕様書から取得）
# WEBKIT_PERSON_ID: 14桁の担当者ID（公式仕様書から取得）
WEBKIT_API_KEY=12345678901234567890
WEBKIT_PERSON_ID=00000000000001

# ========== セキュリティに関する注意 ==========
# このファイルは .gitignore に登録されており、
# コミット対象外になっています
# ローカル開発環境でのみ使用してください
